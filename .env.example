# ================================================================
# RPVP - Arquivo unico de variaveis de ambiente (Docker Compose)
# Copie para .env na raiz do projeto.
# ================================================================

# --- CompreFace (externo) ---------------------------------------
COMPREFACE_URL=http://compreface-ui:80
COMPREFACE_API_KEY=
COMPREFACE_SIMILARITY_THRESHOLD=0.92
COMPREFACE_TIMEOUT_MS=10000

# --- Backend API -------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_TIMEZONE=America/Sao_Paulo
TRUST_PROXY=1
CORS_ORIGINS=https://app.suaempresa.com

AUTH_TOKEN_TTL_HOURS=12
AUTH_PASSWORD_SALT=defina_um_salt_longo_e_aleatorio
INITIAL_ADMIN_NAME=Viana Peixoto
INITIAL_ADMIN_USER=viana.peixoto
INITIAL_ADMIN_PASSWORD=defina_uma_senha_inicial_forte
ALLOW_BOOTSTRAP_ADMIN=false
PRESENCE_COOLDOWN_MS=10000
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_RECOGNIZE_WINDOW_MS=60000
RATE_LIMIT_RECOGNIZE_MAX=30

# --- Banco RPVP (interno do Docker) -----------------------------
# Estes valores devem bater com os definidos no docker-compose.
DB_HOST=rpvp-postgres
DB_PORT=5432
DB_DATABASE=rpvp
DB_USERNAME=vianapeixoto
DB_PASSWORD=defina_uma_senha_forte_para_o_banco
DB_SCHEMA=public

# --- Frontend ----------------------------------------------------
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8080
BACKEND_TARGET=http://backend:3000
FRONTEND_API_BASE=/api